#!/usr/bin/env bash
# SessionStart hook for claude-config plugin
# Injects MD hygiene guidance into every session

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read MD hygiene guidance
md_hygiene_content=$(cat "${PLUGIN_ROOT}/md-hygiene.md" 2>&1 || echo "Error reading md-hygiene.md")

# Escape string for JSON embedding using bash parameter substitution
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

md_hygiene_escaped=$(escape_for_json "$md_hygiene_content")
session_context="**At natural checkpoints, suggest the appropriate skill from the guide below. Never auto-invoke precompact.**\n\n${md_hygiene_escaped}"

# Output context injection as JSON
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF
else
  cat <<EOF
{
  "additional_context": "${session_context}"
}
EOF
fi

exit 0
